/* Easter egg - projet secret "Accès restreint".
   Fausse ligne de projet (injectée en JS, donc invisible pour le SEO). Au survol :
   teaser "ACCÈS REFUSÉ". Au clic : une scène où un personnage surpris ferme les rideaux. */
(function(){
  if(matchMedia('(hover:none)').matches) return; // desktop uniquement
  var plist=document.getElementById('plist'); if(!plist) return;
  var peek=document.getElementById('peek');

  injectCSS();

  // 1) fausse ligne de projet
  var row=document.createElement('div'); row.className='prow prow-secret';
  row.innerHTML='<div class="left"><span class="yr">??</span><div class="pinfo">'+
    '<span class="pname"><svg class="lockico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">'+
      '<rect x="4" y="11" width="16" height="9" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/></svg> Accès restreint</span>'+
    '<span class="ptag">Dossier confidentiel, ne pas ouvrir.</span></div></div>'+
    '<div class="pmeta">Privé<br>Lecture interdite</div>';
  plist.appendChild(row);

  // 2) teaser au survol (réutilise l'aperçu flottant #peek)
  var teaser='<div class="secret-teaser"><svg width="42" height="42" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2">'+
    '<rect x="4" y="11" width="16" height="9" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/></svg><span>ACCÈS REFUSÉ</span></div>';
  if(peek){
    row.addEventListener('mouseenter', function(){ peek.innerHTML=teaser; peek.classList.add('on'); });
    row.addEventListener('mouseleave', function(){ peek.classList.remove('on'); peek.innerHTML=''; });
  }

  // 3) clic -> scène
  row.addEventListener('click', open);

  var modal=null, t1, t2;
  function open(){
    if(peek) peek.classList.remove('on');
    build();
    var scene=modal.querySelector('.scene');
    scene.classList.remove('angry','closed');
    modal.classList.add('open'); document.body.style.overflow='hidden';
    clearTimeout(t1); clearTimeout(t2);
    t1=setTimeout(function(){ scene.classList.add('angry'); }, 550);
    t2=setTimeout(function(){ scene.classList.add('closed'); }, 1500);
  }
  function close(){ if(modal) modal.classList.remove('open'); document.body.style.overflow=''; }

  // --- "Forcer l'accès" : pluie matrix + tremblement sur TOUTE la page ---
  var matrixRAF=null, tDen=null, fxCanvas=null, fxDenied=null, fxResize=null;
  function ensureFx(){
    if(fxCanvas) return;
    fxCanvas=document.createElement('canvas'); fxCanvas.className='smatrix';
    fxDenied=document.createElement('div'); fxDenied.className='sdenied';
    fxDenied.innerHTML='<div class="sdcard"><span class="sdt">ACCÈS REFUSÉ</span>'+
      '<span class="sds">Tentative d\'intrusion enregistrée.</span></div>';
    // attachés à <html> pour rester stables pendant que <body> tremble
    document.documentElement.appendChild(fxCanvas);
    document.documentElement.appendChild(fxDenied);
    fxResize=function(){ fxCanvas.width=innerWidth; fxCanvas.height=innerHeight; };
    fxResize(); addEventListener('resize', fxResize);
  }
  function forceAccess(){
    ensureFx();
    // tremblement de toute la page
    var b=document.body;
    b.classList.remove('pageshake'); void b.offsetWidth; b.classList.add('pageshake');
    setTimeout(function(){ b.classList.remove('pageshake'); }, 720);
    // message accès refusé plein écran
    fxDenied.classList.add('show');
    clearTimeout(tDen); tDen=setTimeout(function(){ fxDenied.classList.remove('show'); }, 2800);
    // pluie matrix plein écran
    runMatrix(fxCanvas);
  }
  function runMatrix(cvs){
    var ctx=cvs.getContext('2d');
    cvs.width=innerWidth; cvs.height=innerHeight;
    cvs.classList.add('on');
    var fs=16, cols=Math.max(1, Math.floor(cvs.width/fs));
    var drops=new Array(cols); for(var i=0;i<cols;i++) drops[i]=Math.random()*-(cvs.height/fs);
    var glyphs='アイウエオカキクケコサシスセソタチツテトabcdefABCDEF0123456789@#$%&*';
    var start=Date.now();
    if(matrixRAF) cancelAnimationFrame(matrixRAF);
    function frame(){
      ctx.fillStyle='rgba(13,8,21,0.12)'; ctx.fillRect(0,0,cvs.width,cvs.height);
      ctx.font='700 '+fs+'px JetBrains Mono, monospace';
      for(var i=0;i<drops.length;i++){
        var y=drops[i]*fs;
        ctx.fillStyle='#eaffb0'; ctx.fillText(glyphs.charAt((Math.random()*glyphs.length)|0), i*fs, y);
        ctx.fillStyle='#c6ff3d'; ctx.fillText(glyphs.charAt((Math.random()*glyphs.length)|0), i*fs, y-fs*1.3);
        if(y>cvs.height && Math.random()>0.975) drops[i]=0;
        drops[i]+=0.85;
      }
      if(Date.now()-start<2600){ matrixRAF=requestAnimationFrame(frame); }
      else { cvs.classList.remove('on'); setTimeout(function(){ ctx.clearRect(0,0,cvs.width,cvs.height); }, 650); matrixRAF=null; }
    }
    frame();
  }

  function build(){
    if(modal) return;
    modal=document.createElement('div'); modal.id='secretModal';
    modal.innerHTML='<div class="sback" data-sclose></div><div class="sbox">'+
      '<button class="sx" data-sclose aria-label="Fermer">✕</button>'+
      '<div class="scene"><div class="swindow">'+
        '<div class="sroom">'+charSVG()+'</div>'+
        '<div class="srod"></div>'+
        '<div class="scurtain left"></div>'+
        '<div class="scurtain right"></div>'+
        '<div class="sbubble">Hé&nbsp;! C\'est privé&nbsp;!</div>'+
      '</div></div>'+
      '<p class="scap">Oups… vous êtes tombé sur un dossier <b>confidentiel</b>.'+
        '<span class="scap2">Contactez-moi pour découvrir ce qui se cache derrière cette fenêtre…</span></p>'+
      '<div class="sacts">'+
        '<button class="sforce" data-sforce type="button">Forcer l\'accès</button>'+
        '<a class="scontact" href="#contact" data-sclose>Me contacter</a>'+
        '<button class="sclosebtn" data-sclose type="button">Je referme</button>'+
      '</div>'+
    '</div>';
    document.body.appendChild(modal);
    [].forEach.call(modal.querySelectorAll('[data-sclose]'), function(el){ el.addEventListener('click', close); });
    [].forEach.call(modal.querySelectorAll('[data-sforce]'), function(el){ el.addEventListener('click', forceAccess); });
    addEventListener('keydown', function(e){ if(e.key==='Escape') close(); });
  }

  function charSVG(){
    return '<svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">'+
      '<path d="M38 200 q0 -58 62 -58 q62 0 62 58 Z" fill="#9b5cff"/>'+
      '<rect x="88" y="118" width="24" height="26" rx="10" fill="#e9b98c"/>'+
      '<circle cx="100" cy="92" r="40" fill="#f1c9a3"/>'+
      '<circle cx="60" cy="94" r="7" fill="#f1c9a3"/><circle cx="140" cy="94" r="7" fill="#f1c9a3"/>'+
      '<path d="M62 84 q4 -42 38 -42 q34 0 38 42 q-12 -16 -38 -16 q-26 0 -38 16 Z" fill="#3a2b1f"/>'+
      '<path d="M74 78 q9 -7 19 -2" stroke="#3a2b1f" stroke-width="3" fill="none" stroke-linecap="round"/>'+
      '<path d="M107 76 q10 -5 19 2" stroke="#3a2b1f" stroke-width="3" fill="none" stroke-linecap="round"/>'+
      '<circle cx="84" cy="92" r="9.5" fill="#fff"/><circle cx="116" cy="92" r="9.5" fill="#fff"/>'+
      '<circle cx="85" cy="93" r="4.6" fill="#1a1430"/><circle cx="117" cy="93" r="4.6" fill="#1a1430"/>'+
      '<ellipse cx="100" cy="114" rx="7" ry="9" fill="#7a3b3b"/>'+
      '<circle cx="73" cy="106" r="6" fill="#f3a9a0" opacity=".6"/><circle cx="127" cy="106" r="6" fill="#f3a9a0" opacity=".6"/>'+
      '</svg>';
  }

  function injectCSS(){
    if(document.getElementById('secretstyle')) return;
    var css=
    '.prow-secret .lockico{width:.52em;height:.52em;vertical-align:baseline;margin-right:.18em;opacity:.8}'+
    '.secret-teaser{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;'+
      'background:linear-gradient(135deg,#3a0d18,#7a1f3a);color:#fff;font-family:Outfit,system-ui,sans-serif;font-weight:700;letter-spacing:.08em}'+
    '.secret-teaser span{font-size:15px}'+
    '#secretModal{position:fixed;inset:0;z-index:9000;display:flex;align-items:center;justify-content:center;padding:24px;'+
      'opacity:0;visibility:hidden;transition:opacity .35s,visibility .35s;font-family:Outfit,system-ui,sans-serif}'+
    '#secretModal.open{opacity:1;visibility:visible}'+
    '#secretModal .sback{position:absolute;inset:0;background:rgba(5,2,12,.74);backdrop-filter:blur(8px)}'+
    '#secretModal .sbox{position:relative;z-index:2;max-width:460px;width:100%;background:#140e22;border:1px solid rgba(255,255,255,.14);'+
      'border-radius:24px;padding:22px;text-align:center;transform:translateY(28px) scale(.97);transition:transform .4s cubic-bezier(.16,1,.3,1)}'+
    '#secretModal.open .sbox{transform:none}'+
    '#secretModal .sx{position:absolute;top:14px;right:16px;width:40px;height:40px;border-radius:50%;background:rgba(0,0,0,.4);'+
      'border:1px solid rgba(255,255,255,.14);color:#fff;font-size:19px;cursor:none;display:flex;align-items:center;justify-content:center;z-index:6}'+
    '.swindow{position:relative;height:300px;border-radius:14px;overflow:hidden;background:#0d0815;border:6px solid #241a38}'+
    '.sroom{position:absolute;inset:0;background:radial-gradient(circle at 50% 42%,#3d2e60,#1d1530);display:flex;align-items:flex-end;justify-content:center}'+
    '.sroom svg{width:172px;height:172px;margin-bottom:-4px}'+
    '@keyframes charShake{0%,100%{transform:translateX(0) rotate(0)}25%{transform:translateX(-4px) rotate(-2deg)}75%{transform:translateX(4px) rotate(2deg)}}'+
    '.scene.angry .sroom svg{animation:charShake .35s ease}'+
    '.srod{position:absolute;top:6px;left:0;right:0;height:6px;background:#c6ff3d;z-index:4}'+
    '.scurtain{position:absolute;top:8px;bottom:0;width:54%;z-index:3;box-shadow:inset 0 0 30px rgba(0,0,0,.45);'+
      'background:repeating-linear-gradient(90deg,#7a1f3a,#7a1f3a 10px,#5e1730 10px,#5e1730 20px);transition:transform .8s cubic-bezier(.6,0,.2,1)}'+
    '.scurtain.left{left:0;transform:translateX(-88%)}'+
    '.scurtain.right{right:0;transform:translateX(88%)}'+
    '.scene.closed .scurtain.left{transform:translateX(0)}'+
    '.scene.closed .scurtain.right{transform:translateX(0)}'+
    '.sbubble{position:absolute;top:20px;left:50%;z-index:5;transform:translateX(-50%) scale(.9);background:#fff;color:#0d0815;'+
      'font-weight:700;font-size:15px;padding:9px 16px;border-radius:14px;opacity:0;transition:opacity .25s ease,transform .25s ease;white-space:nowrap}'+
    '.sbubble::after{content:"";position:absolute;bottom:-7px;left:50%;transform:translateX(-50%);border:7px solid transparent;border-top-color:#fff;border-bottom:0}'+
    '.scene.angry .sbubble{opacity:1;transform:translateX(-50%) scale(1)}'+
    '.scap{color:#a99cc4;font-size:15px;margin:18px 0 16px}'+
    '.scap b{color:#c6ff3d}'+
    '.scap2{display:block;margin-top:8px;font-size:13.5px;color:#8f86a6}'+
    '.sacts{display:flex;gap:10px;justify-content:center;flex-wrap:wrap}'+
    '.scontact{font-family:inherit;font-weight:600;font-size:14px;padding:12px 24px;border-radius:100px;background:#c6ff3d;color:#0d0815;cursor:none;text-decoration:none;display:inline-block}'+
    '.sclosebtn{font-family:inherit;font-weight:600;font-size:14px;padding:12px 24px;border-radius:100px;border:1px solid rgba(255,255,255,.22);background:transparent;color:#f4eeff;cursor:none}'+
    '.sforce{font-family:inherit;font-weight:600;font-size:14px;padding:12px 24px;border-radius:100px;border:1px solid rgba(255,61,129,.55);background:rgba(255,61,129,.12);color:#ff7da6;cursor:none}'+
    '.sforce:hover{background:rgba(255,61,129,.22)}'+
    '@keyframes pageShake{10%,90%{transform:translate(-3px,1px)}20%,80%{transform:translate(5px,-2px)}30%,50%,70%{transform:translate(-9px,2px)}40%,60%{transform:translate(9px,-1px)}}'+
    'body.pageshake{animation:pageShake .72s cubic-bezier(.36,.07,.19,.97)}'+
    '.smatrix{position:fixed;inset:0;width:100vw;height:100vh;z-index:99000;pointer-events:none;opacity:0;transition:opacity .5s ease}'+
    '.smatrix.on{opacity:1}'+
    '.sdenied{position:fixed;inset:0;z-index:99001;display:flex;align-items:center;justify-content:center;'+
      'background:rgba(8,3,10,.45);pointer-events:none;opacity:0;transition:opacity .18s ease}'+
    '.sdenied.show{opacity:1}'+
    '@keyframes sdPulse{0%,100%{transform:scale(1)}50%{transform:scale(1.04)}}'+
    '.sdcard{display:flex;flex-direction:column;align-items:center;gap:8px;padding:26px 42px;border-radius:16px;'+
      'background:rgba(30,6,14,.92);border:1.5px solid #ff3d81;box-shadow:0 0 60px rgba(255,61,129,.6);animation:sdPulse 1s ease-in-out infinite}'+
    '.sdt{font-family:"JetBrains Mono",monospace;font-weight:700;font-size:clamp(24px,5vw,38px);letter-spacing:.14em;color:#ff3d81}'+
    '.sds{font-family:"JetBrains Mono",monospace;font-size:13.5px;color:#ffb3c8;letter-spacing:.04em}';
    var st=document.createElement('style'); st.id='secretstyle'; st.textContent=css; document.head.appendChild(st);
  }
})();
